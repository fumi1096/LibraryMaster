# ============================================================
# voice_agent 环境变量配置模板
# 复制为 .env 并填入实际值
# ============================================================

# DeepSeek API (LLM 对话)
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 远程 RAG 服务地址（另一台机器上的图书检索服务）
# 宿主机上运行: http://host.docker.internal:9014/rag
# 远程机器: http://<IP>:9014/rag
RAG_BASE_URL=http://host.docker.internal:9014/rag

# Agent HTTP Server (Docker 内运行)
AGENT_SERVER_HOST=127.0.0.1
AGENT_SERVER_PORT=9015

# KWS 唤醒词
KWS_WAKEUP_KEYWORD=你好小图
KWS_SILENCE_TIMEOUT_S=2.0
KWS_MAX_RECORD_S=30.0

# 讯飞语音识别 (流式 ASR)
# 从 https://console.xfyun.cn/ 获取
XUNFEI_ASR_APP_ID=your_asr_app_id
XUNFEI_ASR_API_KEY=your_asr_api_key
XUNFEI_ASR_API_SECRET=your_asr_api_secret

# 讯飞超拟人语音合成 (TTS)
# 从 https://console.xfyun.cn/ 获取
XUNFEI_TTS_APP_ID=your_tts_app_id
XUNFEI_TTS_API_KEY=your_tts_api_key
XUNFEI_TTS_API_SECRET=your_tts_api_secret
# 超拟人音色: x4_lingganxiaoyu(女声) / x4_lingganxiaonan(男声)
XUNFEI_TTS_VOICE=x4_lingganxiaoyu
